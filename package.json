{
  "name": "markdeck",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "description": "MarkDeck monorepo workspace",
  "scripts": {
    "dev": "pnpm --filter @markdeck/desktop dev",
    "build": "pnpm --filter @markdeck/desktop build",
    "start": "pnpm --filter @markdeck/desktop start",
    "typecheck": "pnpm --filter @markdeck/desktop typecheck",
    "desktop:test": "pnpm --filter @markdeck/desktop test",
    "desktop:dev": "pnpm --filter @markdeck/desktop dev",
    "desktop:start": "pnpm --filter @markdeck/desktop start",
    "desktop:build": "pnpm --filter @markdeck/desktop build",
    "desktop:pack": "pnpm --filter @markdeck/desktop run pack",
    "desktop:dist": "pnpm --filter @markdeck/desktop run dist"
  }
}
