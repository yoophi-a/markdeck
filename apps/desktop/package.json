{
  "name": "@markdeck/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop app for MarkDeck",
  "author": "yoophi-a",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "start": "electron-vite preview",
    "test": "node --test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && electron-vite build && node ./scripts/sync-main-runtime.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --mac zip",
    "release:mac": "npm run dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "mermaid": "11.6.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "10.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "15.6.1",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "react-grab": "^0.1.29",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.2.1",
    "typescript": "5.8.2",
    "vite": "^5.4.19"
  },
  "build": {
    "appId": "com.yoophi.markdeck",
    "productName": "MarkDeck",
    "directories": {
      "output": "../../release/desktop"
    },
    "files": [
      "out/**/*",
      "package.json",
      "build/**/*"
    ],
    "mac": {
      "target": [
        "dir",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}
