{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@/*": ["./src/renderer/src/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/main/**/*.d.ts",
    "src/preload/**/*.ts",
    "src/preload/**/*.d.ts",
    "src/renderer/src/**/*.ts",
    "src/renderer/src/**/*.tsx",
    "src/renderer/src/**/*.d.ts",
    "electron.vite.config.ts"
  ],
  "exclude": ["node_modules", "out", "dist"]
}
